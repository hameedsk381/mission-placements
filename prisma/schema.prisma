generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("STUDENT") // STUDENT or MANAGER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  submissions   Submission[]
  metrics       StudentMetrics?
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
}
 
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
 
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
 
  @@unique([identifier, token])
}

model StudentMetrics {
  id             String @id @default(cuid())
  userId         String @unique
  user           User   @relation(fields: [userId], references: [id])
  globalRank     Int    @default(0)
  successRate    Float  @default(0.0)
  problemsSolved Int    @default(0)
  studyHours     Float  @default(0.0)
  updatedAt      DateTime @updatedAt
}

model SuccessStory {
  id        String   @id @default(cuid())
  name      String
  role      String
  company   String
  ctc       String
  quote     String
  image     String?
  tags      String // Comma separated tags
  batch     String   @default("2024")
  createdAt DateTime @default(now())
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  type        String   // VIDEO, PDF, SHEET
  description String
  link        String
  category    String
  size        String   @default("1.0 MB")
  date        String   @default("Feb 2026")
  iconName    String   @default("FileText")
  createdAt   DateTime @default(now())
}

model MockTest {
  id          String       @id @default(cuid())
  title       String
  company     String
  duration    Int          // In minutes
  questions   Question[]
  submissions Submission[]
  createdAt   DateTime     @default(now())
}

model Question {
  id         String   @id @default(cuid())
  testId     String
  test       MockTest @relation(fields: [testId], references: [id])
  text       String
  options    Option[]
  correctOpt String   // ID of the correct option
}

model Option {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  text       String
}

model Submission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  testId    String
  test      MockTest @relation(fields: [testId], references: [id])
  score     Float
  answers   String   // JSON string of answers
  createdAt DateTime @default(now())
}
